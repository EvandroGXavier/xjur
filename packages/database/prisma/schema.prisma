// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. SAAS CORE MODULE
model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique // CNPJ/CPF do escritório
  planId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan                     Plan?                    @relation(fields: [planId], references: [id])
  users                    User[]
  trustedDevices           TrustedDevice[]
  contacts                 Contact[]
  contactChannelIdentities ContactChannelIdentity[]
  processes                Process[]
  categories               DocumentCategory[]
  templates                DocumentTemplate[]
  communicationLogs        CommunicationLog[]
  documentHistory          DocumentHistory[]
  financialRecords         FinancialRecord[]
  bankAccounts             BankAccount[]
  bankIntegrations         BankIntegration[]
  bankTransactions         BankTransaction[]
  bankWebhookEvents        BankWebhookEvent[]
  bankReconciliations      BankReconciliation[]
  bankCharges              BankCharge[]
  bankPaymentRequests      BankPaymentRequest[]
  bankSyncJobs             BankSyncJob[]
  relationTypes            RelationType[]
  contactRelations         ContactRelation[]
  assetTypes               AssetType[]
  contactAssets            ContactAsset[]
  financialParties         FinancialParty[]
  transactionSplits        TransactionSplit[]
  financialCategories      FinancialCategory[]

  // Integração Microsoft 365 (OneDrive/SharePoint)
  msTenantId      String?
  msClientId      String?
  msClientSecret  String?
  msAccessToken   String? @db.Text
  msRefreshToken  String? @db.Text
  msDriveId       String? // Drive/Biblioteca onde fica a pasta raiz
  msFolderId      String? // Pasta raiz do escritório no OneDrive
  msObservation   String? @db.Text
  msStorageActive Boolean @default(false)

  // New Modules Relationships
  tags                        Tag[]
  appointments                Appointment[]
  proposals                   Proposal[]
  invoices                    Invoice[]
  fiscalConfig                FiscalConfig?
  products                    Product[]
  suppliers                   Supplier[]
  inventoryMovements          InventoryMovement[]
  tickets                     Ticket[]
  ticketMessages              TicketMessage[]
  waInstances                 WaInstance[]
  connections                 Connection[]
  incomingEvents              IncomingEvent[]
  inventoryConfig             InventoryConfig?
  partyRoles                  PartyRole[]
  partyQualifications         PartyQualification[]
  processParties              ProcessParty[]
  processPartyRepresentations ProcessPartyRepresentation[]
  purchaseOrders              PurchaseOrder[]
  paymentConditions           PaymentCondition[]
  securitySecrets             SecuritySecret[]
  securitySettings            SecuritySetting[]
  agentConversations          AgentConversation[]
  agentMessages               AgentMessage[]
  agentRuns                   AgentRun[]
  agentParticipants           AgentParticipant[]
  agentMessageEvents          AgentMessageEvent[]
  agentMessageLinks           AgentMessageLink[]
  workflows                   Workflow[]
  tenantDocumentSettings      TenantDocumentSetting[]

  // Preferences
  contactRequireOneInfo Boolean @default(true) // Se false, celular/telefone/email ficam não-obrigatórios

  @@map("tenants")
}

model Plan {
  id         String  @id @default(uuid())
  name       String // BASIC, PRO, FULL
  maxUsers   Int
  maxStorage Int // MB
  price      Decimal @db.Decimal(10, 2)

  tenants Tenant[]

  @@map("plans")
}

model User {
  id               String  @id @default(uuid())
  tenantId         String
  name             String
  email            String  @unique
  password         String
  role             String // OWNER, ADMIN, MEMBER
  permissions      Json?
  theme            String  @default("SYSTEM") // SYSTEM, LIGHT, DARK
  soundEnabled     Boolean @default(true)
  sidebarCollapsed Boolean @default(false)

  // Preferences (centralizadas por usuÃ¡rio)
  startupModuleMode String   @default("LAST") // LAST ou HOME
  homeModuleId      String   @default("dashboard")
  lastModuleId      String   @default("dashboard")
  preferences       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant                     Tenant              @relation(fields: [tenantId], references: [id])
  trustedDevices             TrustedDevice[]
  assignedAgentConversations AgentConversation[] @relation("AssignedAgentConversations")
  agentParticipants          AgentParticipant[]  @relation("AgentParticipantUser")
  agentMessageLinks          AgentMessageLink[]  @relation("AgentMessageLinkedBy")

  @@map("users")
}

model TrustedDevice {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String
  name       String
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, revokedAt])
  @@map("trusted_devices")
}

// 2.1 ENTIDADE ÂNCORA: CONTACT
model Contact {
  id         String @id @default(uuid())
  tenantId   String
  name       String
  personType String @default("PF") // PF ou PJ

  // Campos Gerais
  document       String? // CPF/CNPJ (Mantido para busca rápida/compatibilidade)
  whatsapp       String?
  // Canonical WhatsApp identity (digits only, E.164 without '+'). Ex: 5531199999999
  whatsappE164   String?
  // Canonical WhatsApp thread id used by Evolution/Baileys. Ex: 5531199999999@s.whatsapp.net
  whatsappFullId String?
  email          String?
  phone          String?
  notes          String?
  category       String? // Cliente, Fornecedor, Parte Contrária, Perito, Funcionário
  password       String? // Senha para acesso ao sistema
  profilePicUrl  String? // URL da foto de perfil
  metadata       Json?
  active         Boolean @default(true)

  // Detalhes Específicos (1:1)
  pfDetails PersonDetailPF?
  pjDetails PersonDetailPJ?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  addresses          Address[]
  additionalContacts AdditionalContact[]
  communications     CommunicationLog[]
  relationsFrom      ContactRelation[]   @relation("RelationsFrom")
  relationsTo        ContactRelation[]   @relation("RelationsTo")
  assets             ContactAsset[]
  bankAccounts       BankAccount[]       @relation("BankAccounts")

  // New Modules Relationships
  tags                      ContactTag[]
  appointmentParticipations AppointmentParticipant[]
  proposals                 Proposal[]               @relation("ProposalClient")
  proposalsAsSeller         Proposal[]               @relation("ProposalSeller")
  inventoryConfigAsSeller   InventoryConfig[]        @relation("InventoryConfigDefaultSeller")
  invoices                  Invoice[]
  tickets                   Ticket[]
  processParties            ProcessParty[]
  financialParties          FinancialParty[]
  products                  Product[]
  purchaseOrders            PurchaseOrder[] // Como fornecedor
  purchasesAsBuyer          PurchaseOrder[]          @relation("PurchaseOrderBuyer") // Como comprador
  agentConversations        AgentConversation[]
  agentParticipants         AgentParticipant[]       @relation("AgentParticipantContact")
  channelIdentities         ContactChannelIdentity[]
  ticketMessages            TicketMessage[]
  incomingEvents            IncomingEvent[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([document]) // Index on document generic field
  @@index([whatsappE164])
  @@index([whatsappFullId])
  @@index([personType])
  @@index([category])
  @@map("contacts")
}

// Stores external identifiers (aliases) that can map back to a single Contact.
// This is especially important for WhatsApp LIDs (@lid) and provider-specific JID variants.
model ContactChannelIdentity {
  id         String   @id @default(uuid())
  tenantId   String
  contactId  String
  channel    String // WHATSAPP, TELEGRAM, EMAIL, ...
  provider   String? // EVOLUTION, BAILEYS, META, ...
  externalId String // ex: 5531...@s.whatsapp.net, ...@lid, group jid, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, externalId])
  @@index([tenantId, contactId, channel])
  @@map("contact_channel_identities")
}

model PersonDetailPF {
  id        String @id @default(uuid())
  contactId String @unique

  cpf         String?
  rg          String?
  rgIssuer    String?
  rgIssueDate DateTime?
  birthDate   DateTime?

  nis         String?
  pis         String?
  ctps        String?
  motherName  String?
  fatherName  String?
  profession  String?
  nationality String?
  naturality  String?
  gender      String?
  civilStatus String?

  // CNH (New Fields)
  cnh               String?
  cnhIssuer         String?
  cnhIssueDate      DateTime?
  cnhCategory       String?
  cnhExpirationDate DateTime?
  fullName          String? // Nome completo legal (diferente do display name)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("person_details_pf")
}

model PersonDetailPJ {
  id        String @id @default(uuid())
  contactId String @unique

  cnpj                  String?
  companyName           String? // Razão Social
  tradingName           String? // Nome Fantasia
  stateRegistration     String? // Inscrição Estadual
  municipalRegistration String? // Inscrição Municipal

  // Dados Expandidos PJ (Receita Federal)
  openingDate       DateTime?
  size              String?
  legalNature       String?
  mainActivity      Json?
  sideActivities    Json?
  shareCapital      Decimal?  @db.Decimal(15, 2)
  status            String?
  statusDate        DateTime?
  statusReason      String?
  specialStatus     String?
  specialStatusDate DateTime?
  pjQsa             Json?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("person_details_pj")
}

model RelationType {
  id          String   @id @default(uuid())
  tenantId    String
  name        String // Ex: Pai, Sócio
  reverseName String? // Ex: Filho (opcional, se null usa name)
  isBilateral Boolean  @default(false)
  createdAt   DateTime @default(now())

  relations ContactRelation[]
  tenant    Tenant            @relation(fields: [tenantId], references: [id])

  @@map("relation_types")
}

model ContactRelation {
  id             String @id @default(uuid())
  tenantId       String
  fromContactId  String
  toContactId    String
  relationTypeId String

  fromContact  Contact      @relation("RelationsFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact    Contact      @relation("RelationsTo", fields: [toContactId], references: [id], onDelete: Cascade)
  relationType RelationType @relation(fields: [relationTypeId], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([fromContactId, toContactId, relationTypeId]) // Evitar duplicatas exatas
  @@map("contact_relations")
}

model AssetType {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  assets ContactAsset[]
  tenant Tenant         @relation(fields: [tenantId], references: [id])

  @@map("asset_types")
}

model ContactAsset {
  id              String    @id @default(uuid())
  tenantId        String
  contactId       String
  assetTypeId     String
  description     String
  acquisitionDate DateTime?
  value           Decimal?  @db.Decimal(10, 2)
  writeOffDate    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assetType AssetType @relation(fields: [assetTypeId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("contact_assets")
}

model Address {
  id         String  @id @default(uuid())
  contactId  String
  type       String  @default("Principal") // Principal, Comercial, Residencial, etc.
  zipCode    String
  street     String
  number     String
  complement String?
  district   String? // Bairro
  city       String
  state      String
  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model AdditionalContact {
  id                   String  @id @default(uuid())
  contactId            String
  type                 String // EMAIL, PHONE, ETC
  value                String
  nomeContatoAdicional String?
  contact              Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("additional_contacts")
}

// 2.2 MÓDULOS JURÍDICOS E FINANCEIROS
model Process {
  id       String  @id @default(uuid())
  tenantId String
  cnj      String? // Opcional para Casos/Consultivo

  // Identificação Interna
  category    String  @default("JUDICIAL") // JUDICIAL | EXTRAJUDICIAL
  title       String? // Título do Caso (ex: Análise Contratual)
  code        String? // Código Interno (ex: CASO-25-001)
  folder      String? // Pasta na Nuvem (Z:\, Google Drive)
  description String? @db.Text // Descrição Rica (HTML/Markdown)

  // Microsoft 365 Integration e Integração Local
  msDriveId   String? // ID da pasta do processo no OneDrive
  msFolderUrl String? // Link do OneDrive para acesso rápido
  localFolder String? // Caminho físico no PC local Windows (C:\...)

  // Detalhes Jurídicos
  npu               String? // Numeração Única (Normalizada)
  court             String? // Tribunal (TJMG, TRF1, etc) - Opcional para Consultivo
  courtSystem       String? // Sistema (PJe, Eproc, Projudi)
  vars              String? // Vara / Órgão Julgador
  district          String? // Comarca
  status            String // OPORTUNIDADE, ATIVO, SUSPENSO, ARQUIVADO
  responsibleLawyer String? // Advogado Responsável (Nome ou ID)

  // Classificação
  area             String? // Cível, Trabalhista, Criminal
  subject          String? // Assunto Principal
  class            String? // Classe Processual
  distributionDate DateTime? // Data de Distribuição
  judge            String? // Magistrado
  value            Decimal?  @db.Decimal(15, 2)

  // Partes (Snapshot JSON para importação rápida)
  parties Json? // [{ name: "João", type: "AUTOR", cpf: "..." }]

  // Automação
  lastCrawledAt DateTime? // Última atualização via robô
  autoUpdate    Boolean   @default(true)
  metadata      Json? // Dados crus do crawler

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  timeline                    ProcessTimeline[]
  financials                  FinancialRecord[]
  appointments                Appointment[]
  processParties              ProcessParty[]
  processPartyRepresentations ProcessPartyRepresentation[]
  tags                        ProcessTag[]
  agentConversations          AgentConversation[]
  agentMessageLinks           AgentMessageLink[]
  documents                   DocumentHistory[]
  ticketMessages              TicketMessage[]

  workflowId String?
  workflow   Workflow? @relation(fields: [workflowId], references: [id])

  @@unique([tenantId, code])
  @@unique([tenantId, cnj])
  @@map("processes")
}

// 2.3 PARTES PROCESSUAIS (Vínculo Processo ↔ Contato)
model PartyRole {
  id        String   @id @default(uuid())
  tenantId  String
  name      String // Ex: AUTOR, RÉU, TESTEMUNHA, PERITO
  category  String? // POLO_ATIVO, POLO_PASSIVO, OUTROS
  isDefault Boolean  @default(false) // Roles pré-cadastrados (seed)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  processParties ProcessParty[]
  tenant         Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("party_roles")
}

model PartyQualification {
  id        String   @id @default(uuid())
  tenantId  String
  name      String // Ex: CLIENTE, CONTRÁRIO, TESTEMUNHA, TERCEIRO
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  processParties ProcessParty[]
  tenant         Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("party_qualifications")
}

model ProcessParty {
  id              String   @id @default(uuid())
  tenantId        String
  processId       String
  contactId       String
  roleId          String
  qualificationId String?
  isClient        Boolean  @default(false) // É nosso cliente neste processo?
  isOpposing      Boolean  @default(false) // É parte contrária?
  notes           String? // Observações sobre a parte
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  process               Process                      @relation(fields: [processId], references: [id], onDelete: Cascade)
  contact               Contact                      @relation(fields: [contactId], references: [id])
  role                  PartyRole                    @relation(fields: [roleId], references: [id])
  qualification         PartyQualification?          @relation(fields: [qualificationId], references: [id])
  tenant                Tenant                       @relation(fields: [tenantId], references: [id])
  representativeLinks   ProcessPartyRepresentation[] @relation("ProcessPartyPrincipal")
  representedPartyLinks ProcessPartyRepresentation[] @relation("ProcessPartyRepresentative")

  @@unique([processId, contactId, roleId]) // Evita duplicata exata
  @@map("process_parties")
}

model ProcessPartyRepresentation {
  id                    String   @id @default(uuid())
  tenantId              String
  processId             String
  partyId               String
  representativePartyId String
  createdAt             DateTime @default(now())

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  process             Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  party               ProcessParty @relation("ProcessPartyPrincipal", fields: [partyId], references: [id], onDelete: Cascade)
  representativeParty ProcessParty @relation("ProcessPartyRepresentative", fields: [representativePartyId], references: [id], onDelete: Cascade)

  @@unique([partyId, representativePartyId])
  @@index([processId, partyId])
  @@index([processId, representativePartyId])
  @@map("process_party_representations")
}

model ProcessTimeline {
  id          String   @id @default(uuid())
  processId   String
  title       String
  description String?
  date        DateTime
  type        String // MOVEMENT, MESSAGE, FILE
  source      String? // CRAWLER, MANUAL, USER_IMPORT
  metadata    Json? // Store file paths or message IDs here
  createdAt   DateTime @default(now())

  // New Fields for DR.X
  displayId           String? // Evento/ID original do tribunal
  internalSequence    Int? // Sequência 1, 2, 3 do DR.X
  origin              String? // TRIBUNAL_PJE, TRIBUNAL_EPROC, INTERNO, IA
  internalDate        DateTime? // Data alvo para solução do escritório
  fatalDate           DateTime? // Prazo fatal do sistema judicial
  responsibleAdvogado String? // Nome ou ID do advogado
  aiSummary           String? // Resumo simplificado para o cliente
  clientMessage       String? // Texto formatado para envio via WhatsApp

  // --- MOTOR DE WORKFLOW ---
  category           String?   @default("REGISTRO") // REGISTRO, ACAO, AGENDA
  status             String?   @default("PENDENTE") // PENDENTE, EM_TRATAMENTO, CONCLUIDO
  priority           String?   @default("MEDIA") // BAIXA, MEDIA, ALTA, URGENTE
  requesterName      String? // Quem solicitou o andamento
  responsibleName    String? // Quem deve tratar a ação
  completedAt        DateTime? // Data de conclusão
  completedBy        String? // Quem concluiu
  conclusionNotes    String? // Observação da conclusão
  responsibleHistory Json? // Histórico de responsáveis [{name, date}]
  templateCode       String? // Identificador do Template que gerou este andamento
  parentTimelineId   String? // FK para o andamento "Pai"

  parentTimeline ProcessTimeline?  @relation("WorkflowSequence", fields: [parentTimelineId], references: [id])
  childTimelines ProcessTimeline[] @relation("WorkflowSequence")

  process           Process            @relation(fields: [processId], references: [id], onDelete: Cascade)
  agentMessageLinks AgentMessageLink[]
  documents         DocumentHistory[]

  workflowStepId String?
  workflowStep   WorkflowStep?        @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)
  tags           ProcessTimelineTag[]

  @@index([processId, date])
  @@index([workflowStepId])
  @@map("process_timelines")
}

model FinancialRecord {
  id              String    @id @default(uuid())
  tenantId        String
  processId       String?
  purchaseOrderId String?
  proposalId      String?
  bankAccountId   String?
  categoryId      String? // FK para FinancialCategory
  description     String
  amount          Decimal   @db.Decimal(15, 2)
  dueDate         DateTime
  paymentDate     DateTime?
  status          String // PENDING, PAID, CANCELLED, OVERDUE, PARTIAL
  type            String // INCOME (Receita), EXPENSE (Despesa)
  category        String? // Legado: texto livre (Honorários, Custas, etc)
  paymentMethod   String? // PIX, BOLETO, TED, DINHEIRO, CARTAO
  notes           String?   @db.Text

  // === ENCARGOS & DESCONTOS ===
  fine               Decimal? @db.Decimal(15, 2) // Multa
  interest           Decimal? @db.Decimal(15, 2) // Juros
  monetaryCorrection Decimal? @db.Decimal(15, 2) // Correção monetária
  discount           Decimal? @db.Decimal(15, 2) // Desconto
  discountType       String? // VALUE (valor fixo) ou PERCENTAGE (percentual)
  amountFinal        Decimal? @db.Decimal(15, 2) // Valor final calculado (amount + encargos - descontos)
  amountPaid         Decimal? @db.Decimal(15, 2) // Valor efetivamente pago

  // === PARCELAMENTO ===
  parentId          String? // FK auto-referencial: transação-mãe
  installmentNumber Int? // Número da parcela (1, 2, 3...)
  totalInstallments Int? // Total de parcelas
  periodicity       String? // MONTHLY, BIWEEKLY, WEEKLY, CUSTOM
  isResidual        Boolean @default(false) // Parcela residual de pagamento parcial?

  paymentConditionId String? // Vínculo com a Condição de Pagamento (se gerado via regra)

  // === ORIGEM ===
  origin String? @default("MANUAL") // MANUAL, NF, COMPRA, PROPOSTA, JUDICIAL

  metadata Json? // Meta informações como anexo, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  invoice           Invoice?
  process           Process?           @relation(fields: [processId], references: [id])
  purchaseOrder     PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  proposal          Proposal?          @relation(fields: [proposalId], references: [id])
  bankAccount       BankAccount?       @relation(fields: [bankAccountId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  financialCategory FinancialCategory? @relation(fields: [categoryId], references: [id])
  paymentCondition  PaymentCondition?  @relation(fields: [paymentConditionId], references: [id])
  parties           FinancialParty[]
  splits            TransactionSplit[]
  bankReconciliations BankReconciliation[]
  bankCharges         BankCharge[]
  bankPaymentRequests BankPaymentRequest[]

  // Auto-relacionamento (Parcelas / Residuais)
  parent   FinancialRecord?  @relation("Installments", fields: [parentId], references: [id])
  children FinancialRecord[] @relation("Installments")

  // Tags
  tags FinancialRecordTag[]
  ticketMessages TicketMessage[]

  @@index([parentId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, dueDate])
  @@map("financial_records")
}

model BankAccount {
  id            String   @id @default(uuid())
  tenantId      String
  title         String // Nome/Título da conta
  bankName      String?
  accountType   String // CHECKING (Corrente), SAVINGS (Poupança)
  accountNumber String?
  agency        String?
  balance       Decimal  @default(0) @db.Decimal(10, 2)
  contactId     String? // ID do Titular (opcional)
  isActive      Boolean  @default(true)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  contact          Contact?          @relation("BankAccounts", fields: [contactId], references: [id])
  financialRecords FinancialRecord[]
  bankIntegrations BankIntegration[]
  bankTransactions BankTransaction[]
  bankCharges      BankCharge[]
  bankPaymentRequests BankPaymentRequest[]

  @@index([contactId])
  @@map("bank_accounts")
}

model BankIntegration {
  id                    String   @id @default(uuid())
  tenantId              String
  bankAccountId         String?
  provider              String
  displayName           String
  environment           String   @default("SANDBOX")
  status                String   @default("DRAFT")
  isActive              Boolean  @default(true)
  credentialSecretId    String?
  certificateSecretId   String?
  webhookSecretId       String?
  webhookUrl            String?
  webhookEnabled        Boolean  @default(false)
  externalAccountId     String?
  accountHolderDocument String?
  accountHolderName     String?
  branchCode            String?
  accountNumber         String?
  metadata              Json?
  lastHealthcheckAt     DateTime?
  lastHealthcheckStatus String?
  lastHealthcheckError  String?  @db.Text
  lastSyncAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  bankAccount         BankAccount?          @relation(fields: [bankAccountId], references: [id])
  bankTransactions    BankTransaction[]
  webhookEvents       BankWebhookEvent[]
  reconciliations     BankReconciliation[]
  charges             BankCharge[]
  paymentRequests     BankPaymentRequest[]
  syncJobs            BankSyncJob[]

  @@index([tenantId, provider, isActive])
  @@index([bankAccountId])
  @@map("bank_integrations")
}

model BankTransaction {
  id                    String   @id @default(uuid())
  tenantId              String
  bankIntegrationId     String
  bankAccountId         String?
  externalTransactionId String
  direction             String
  entryType             String
  status                String   @default("CAPTURED")
  occurredAt            DateTime
  postedAt              DateTime?
  amount                Decimal  @db.Decimal(15, 2)
  feeAmount             Decimal? @db.Decimal(15, 2)
  description           String
  counterpartyName      String?
  counterpartyDocument  String?
  txid                  String?
  endToEndId            String?
  reconciliationStatus  String   @default("PENDING")
  rawPayload            Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  bankIntegration BankIntegration     @relation(fields: [bankIntegrationId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount?        @relation(fields: [bankAccountId], references: [id])
  reconciliations BankReconciliation[]

  @@unique([bankIntegrationId, externalTransactionId])
  @@index([tenantId, occurredAt])
  @@index([bankAccountId])
  @@map("bank_transactions")
}

model BankWebhookEvent {
  id              String   @id @default(uuid())
  tenantId        String
  bankIntegrationId String
  provider        String
  eventType       String
  externalEventId String?
  status          String   @default("RECEIVED")
  receivedAt      DateTime @default(now())
  processedAt     DateTime?
  processingError String?  @db.Text
  rawPayload      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  bankIntegration BankIntegration @relation(fields: [bankIntegrationId], references: [id], onDelete: Cascade)

  @@index([tenantId, provider, status])
  @@index([bankIntegrationId, receivedAt])
  @@map("bank_webhook_events")
}

model BankReconciliation {
  id                String   @id @default(uuid())
  tenantId          String
  bankIntegrationId String
  bankTransactionId String
  financialRecordId String
  matchType         String
  status            String   @default("MATCHED")
  matchedBy         String?
  notes             String?  @db.Text
  matchedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  bankIntegration BankIntegration @relation(fields: [bankIntegrationId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)

  @@unique([bankTransactionId, financialRecordId])
  @@index([tenantId, status])
  @@map("bank_reconciliations")
}

model BankCharge {
  id                 String   @id @default(uuid())
  tenantId           String
  bankIntegrationId  String
  bankAccountId      String?
  financialRecordId  String
  provider           String
  chargeType         String
  status             String   @default("DRAFT")
  externalChargeId   String?
  txid               String?
  barcode            String?
  digitableLine      String?
  pixQrCode          String?  @db.Text
  pixCopyPaste       String?  @db.Text
  dueDate            DateTime?
  amount             Decimal  @db.Decimal(15, 2)
  rawRequest         Json?
  rawResponse        Json?
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  bankIntegration BankIntegration @relation(fields: [bankIntegrationId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount?    @relation(fields: [bankAccountId], references: [id])
  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, provider])
  @@map("bank_charges")
}

model BankPaymentRequest {
  id                  String   @id @default(uuid())
  tenantId            String
  bankIntegrationId   String
  bankAccountId       String?
  financialRecordId   String
  provider            String
  paymentType         String
  status              String   @default("DRAFT")
  externalPaymentId   String?
  approvedByUserId    String?
  beneficiaryName     String?
  beneficiaryDocument String?
  amount              Decimal  @db.Decimal(15, 2)
  executedAt          DateTime?
  approvedAt          DateTime?
  rawRequest          Json?
  rawResponse         Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  bankIntegration BankIntegration @relation(fields: [bankIntegrationId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount?    @relation(fields: [bankAccountId], references: [id])
  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, provider])
  @@map("bank_payment_requests")
}

model BankSyncJob {
  id                String   @id @default(uuid())
  tenantId          String
  bankIntegrationId String
  jobType           String
  status            String   @default("PENDING")
  startedAt         DateTime?
  finishedAt        DateTime?
  summary           String?  @db.Text
  rawResult         Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  bankIntegration BankIntegration @relation(fields: [bankIntegrationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, jobType])
  @@map("bank_sync_jobs")
}

model FinancialParty {
  id                String   @id @default(uuid())
  tenantId          String
  financialRecordId String
  contactId         String
  role              String // CREDITOR, DEBTOR
  amount            Decimal? @db.Decimal(10, 2)
  notes             String?

  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id])
  tenant          Tenant          @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([financialRecordId, contactId, role])
  @@map("financial_parties")
}

// === RATEIO DE TRANSAÇÃO ===
model TransactionSplit {
  id                String    @id @default(uuid())
  tenantId          String
  financialRecordId String
  contactId         String
  role              String // CREDITOR ou DEBTOR
  amount            Decimal   @db.Decimal(15, 2) // Valor absoluto do rateio
  percentage        Decimal?  @db.Decimal(5, 2) // % do total (ex: 33.33)
  description       String? // Descrição opcional do rateio
  isPaid            Boolean   @default(false)
  paidAt            DateTime?
  notes             String?

  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financialRecordId])
  @@map("transaction_splits")
}

// === CATEGORIAS FINANCEIRAS DINÂMICAS ===
model FinancialCategory {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  type     String? // INCOME, EXPENSE, BOTH
  color    String? // Hex color
  icon     String? // Ícone (opcional)
  parentId String? // Subcategorias
  active   Boolean @default(true)

  parent   FinancialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children FinancialCategory[] @relation("CategoryTree")
  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  records  FinancialRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("financial_categories")
}

// 3. A "INVENÇÃO DR.X": TRIAGEM E COMUNICAÇÃO
model CommunicationLog {
  id          String   @id @default(uuid())
  tenantId    String
  contactId   String?
  direction   String // INBOUND, OUTBOUND
  channel     String // WHATSAPP
  content     String
  mediaUrl    String? // Caminho local do arquivo
  mediaType   String? // AUDIO, IMAGE, PDF
  status      String // RECEIVED, TRIAGED, ARCHIVED
  processedBy String? // AI or AGENT
  createdAt   DateTime @default(now())

  contact Contact? @relation(fields: [contactId], references: [id])
  tenant  Tenant   @relation(fields: [tenantId], references: [id])

  @@map("communication_logs")
}

// 4. MÓDULO DE MODELOS DE DOCUMENTOS (DR.X MODELS)

model DocumentCategory {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  parentId String?

  parent    DocumentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  DocumentCategory[] @relation("CategoryHierarchy")
  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  templates DocumentTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("document_categories")
}

model DocumentTemplate {
  id         String  @id @default(uuid())
  tenantId   String?
  title      String
  content    String  @db.Text
  categoryId String?

  // Biblioteca Mestre do Sistema (global) vs Modelos do Escritório (por tenant)
  isSystemTemplate Boolean @default(false)
  systemKey        String? @unique // Identificador estável para upsert de templates do sistema (ex: PETICAO_INICIAL_GENERIC)
  sourceTemplateId String? // ID do template de origem (ex: cópia de um System Template)

  description      String?
  tags             Json? // ex: ["Cível","CPC","DrX"]
  preferredStorage String? // WORD_ONLINE | GOOGLE_DOCS
  metadata         Json? // Visual Law, seções, comentários internos (não impressos)

  category DocumentCategory?     @relation(fields: [categoryId], references: [id])
  tenant   Tenant?               @relation(fields: [tenantId], references: [id])
  history  DocumentHistory[]
  tagLinks DocumentTemplateTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isSystemTemplate])
  @@index([sourceTemplateId])
  @@map("document_templates")
}

model DocumentHistory {
  id         String  @id @default(uuid())
  tenantId   String
  templateId String?
  processId  String?
  timelineId String?
  title      String
  content    String  @db.Text
  snapshot   Json? // Stores the variables values at time of creation
  status     String // DRAFT, FINALIZED

  // Microsoft 365 Integration
  msFileId  String? // ID do docx no OneDrive
  msFileUrl String? // Link de edição no Word Online

  // Google Workspace (futuro)
  gFileId  String?
  gFileUrl String?

  template DocumentTemplate? @relation(fields: [templateId], references: [id])
  process  Process?          @relation(fields: [processId], references: [id], onDelete: SetNull)
  timeline ProcessTimeline?  @relation(fields: [timelineId], references: [id], onDelete: SetNull)
  tenant   Tenant            @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, processId])
  @@index([timelineId])
  @@map("document_history")
}

model DocumentSettings {
  id    String  @id @default(uuid())
  key   String  @unique // HEADER, FOOTER, FONT_FAMILY
  value String?

  updatedAt DateTime @updatedAt

  @@map("document_settings")
}

model TenantDocumentSetting {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     String?  @db.Text
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_document_settings")
}

// 5. MÓDULO DE ETIQUETAS (TAGS TRANSVERSAIS)
model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String // Hex code
  textColor String? // Hex code
  scope     Json? // ["CONTACT", "PROCESS", "FINANCE", "TASK"]
  usage     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  contacts          ContactTag[]
  processes         ProcessTag[]
  financialRecords  FinancialRecordTag[]
  timelines         ProcessTimelineTag[]
  documentTemplates DocumentTemplateTag[]

  @@map("tags")
}

model DocumentTemplateTag {
  id         String @id @default(uuid())
  templateId String
  tagId      String

  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tag      Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([templateId, tagId])
  @@map("tags_on_document_templates")
}

model ContactTag {
  id        String @id @default(uuid())
  tagId     String
  contactId String

  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([tagId, contactId])
  @@map("tags_on_contacts")
}

model ProcessTag {
  id        String @id @default(uuid())
  tagId     String
  processId String

  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([tagId, processId])
  @@map("tags_on_processes")
}

model FinancialRecordTag {
  id                String @id @default(uuid())
  tagId             String
  financialRecordId String

  tag             Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)
  financialRecord FinancialRecord @relation(fields: [financialRecordId], references: [id], onDelete: Cascade)

  @@unique([tagId, financialRecordId])
  @@map("tags_on_financial_records")
}

model ProcessTimelineTag {
  id         String @id @default(uuid())
  tagId      String
  timelineId String

  tag      Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)
  timeline ProcessTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@unique([tagId, timelineId])
  @@map("tags_on_timelines")
}

// 6. MÓDULO AGENDA (COMPROMISSOS)
model Appointment {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  description String?
  type        String // AUDIENCIA, PRAZO, REUNIAO, INTIMACAO
  startAt     DateTime
  endAt       DateTime
  status      String // SCHEDULED, CONFIRMED, IN_PROGRESS, DONE, CANCELED, RESCHEDULED
  location    String? // Físico ou Link (Zoom/Meet)

  // Vínculos
  processId String?
  process   Process? @relation(fields: [processId], references: [id])

  recurrence Json? // Regra de recorrência (RRule)

  participants AppointmentParticipant[]

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model AppointmentParticipant {
  id            String  @id @default(uuid())
  appointmentId String
  contactId     String? // Pode ser um contato da base
  name          String? // Ou apenas um nome avulso
  role          String // RESPONSABLE, CLIENT, WITNESS, EXPERT
  confirmed     Boolean @default(false)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  contact     Contact?    @relation(fields: [contactId], references: [id])

  @@map("appointment_participants")
}

// 7. MÓDULO ESTOQUE (PRODUTOS & MOVIMENTAÇÕES)
model Product {
  id                   String   @id @default(uuid())
  tenantId             String
  name                 String
  description          String?
  sku                  String? // Código de estoque
  barcode              String?
  ncm                  String? // Classificação Fiscal
  cest                 String? // Substituição Tributária
  unit                 String   @default("UN") // UN, KG, LT, H (serviço)
  type                 String   @default("PRODUCT") // PRODUCT ou SERVICE
  originCode           String?
  defaultCfopSale      String?
  cstIcms              String?
  csosn                String?
  cstPis               String?
  cstCofins            String?
  cstIpi               String?
  icmsRate             Decimal? @db.Decimal(8, 4)
  pisRate              Decimal? @db.Decimal(8, 4)
  cofinsRate           Decimal? @db.Decimal(8, 4)
  ipiRate              Decimal? @db.Decimal(8, 4)
  serviceCode          String?
  serviceCodeMunicipal String?
  serviceNature        String?
  nbs                  String?
  issRate              Decimal? @db.Decimal(8, 4)
  minStock             Int      @default(0)
  currentStock         Int      @default(0)
  costPrice            Decimal? @db.Decimal(10, 2)
  sellPrice            Decimal? @db.Decimal(10, 2)
  isActive             Boolean  @default(true)

  // E-commerce & Logistics
  images      String[] // URLs das imagens do produto
  weight      Decimal? @db.Decimal(10, 3) // Peso em Kg
  width       Decimal? @db.Decimal(10, 2) // Largura em cm
  height      Decimal? @db.Decimal(10, 2) // Altura em cm
  length      Decimal? @db.Decimal(10, 2) // Comprimento em cm
  category    String? // Categoria para e-commerce/marketplace
  brand       String? // Marca do produto
  isEcommerce Boolean  @default(false) // Se o produto está visível no ecommerce

  supplierId String?
  supplier   Contact? @relation(fields: [supplierId], references: [id])

  movements          InventoryMovement[]
  proposalItems      ProposalItem[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceItems       InvoiceItem[]       @relation("ProductInvoiceItems")
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("products")
}

model Supplier {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  document String? // CNPJ
  email    String?
  phone    String?

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@map("suppliers")
}

model InventoryMovement {
  id         String   @id @default(uuid())
  tenantId   String
  productId  String
  type       String // IN (Entrada), OUT (Saída), ADJUST (Ajuste)
  quantity   Int
  unitPrice  Decimal? @db.Decimal(10, 2)
  totalPrice Decimal? @db.Decimal(10, 2)
  reason     String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@map("inventory_movements")
}

// 8. MÓDULO ATENDIMENTO V2 (OMNICHANNEL TICKETS)
model Ticket {
  id       String @id @default(uuid())
  tenantId String
  code     Int    @default(autoincrement()) // Protocolo numérico amigável
  title    String
  status   String // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  priority String // LOW, MEDIUM, HIGH, URGENT
  channel  String // WHATSAPP, EMAIL, PHONE, WEBCHAT

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assigneeId String? // Usuário responsável (User ID)
  queue      String? // Departamento (FINANCEIRO, JURIDICO)

  isPinned      Boolean   @default(false)
  waitingReply  Boolean   @default(false)
  lastMessageAt DateTime? @default(now())
  scheduledTo   DateTime?

  messages           TicketMessage[]
  agentConversations AgentConversation[]

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model IncomingEvent {
  id                    String    @id @default(uuid())
  tenantId              String
  connectionId          String?
  contactId             String?
  channel               String
  provider              String?
  eventType             String
  direction             String?
  sourceAddress         String?
  externalThreadId      String?
  externalParticipantId String?
  externalMessageId     String?
  externalPhone         String?
  externalFullId        String?
  externalLid           String?
  payload               Json?
  normalizedPayload     Json?
  status                String    @default("PENDING") // PENDING, PROCESSING, PROCESSED, FAILED, DEAD_LETTER
  retryCount            Int       @default(0)
  nextAttemptAt         DateTime?
  processingStartedAt   DateTime?
  processedAt           DateTime?
  processingError       String?   @db.Text
  receivedAt            DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  connection    Connection?    @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ticketMessage TicketMessage?

  @@index([tenantId, status, nextAttemptAt])
  @@index([tenantId, channel, receivedAt])
  @@index([connectionId, receivedAt])
  @@index([tenantId, externalMessageId])
  @@map("incoming_events")
}

model TicketMessage {
  id                    String    @id @default(uuid())
  tenantId              String?
  ticketId              String?
  contactId             String?
  processId             String?
  connectionId          String?
  financialRecordId     String?
  incomingEventId       String?   @unique
  externalId            String?   @unique
  externalThreadId      String?
  externalParticipantId String?
  channel               String    @default("WHATSAPP")
  direction             String    @default("OUTBOUND") // INBOUND, OUTBOUND, INTERNAL
  status                String    @default("PENDING") // PENDING, SENT, DELIVERED, READ, PLAYED, FAILED, SCHEDULED, RECEIVED
  senderType            String // USER (Agente), CONTACT (Cliente), SYSTEM (Bot)
  senderId              String? // ID do User ou Contact
  content               String    @db.Text
  textContent           String?   @db.Text
  contentType           String // TEXT, IMAGE, AUDIO, FILE
  mediaUrl              String?
  quotedId              String?
  scheduledAt           DateTime? // Time when the message should be sent
  sentAt                DateTime?
  deliveredAt           DateTime?
  readAt                DateTime?
  aiAnalysis            Json?
  transcriptionStatus   String?   @default("NOT_REQUIRED") // NOT_REQUIRED, PENDING, PROCESSING, COMPLETED, FAILED

  reactions Json? // [{ emoji: "👍", userId: "..." }]
  metadata  Json? // Waveforms, thumbnails, etc.

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  ticket          Ticket?          @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  contact         Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  process         Process?         @relation(fields: [processId], references: [id], onDelete: SetNull)
  connection      Connection?      @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  financialRecord FinancialRecord? @relation(fields: [financialRecordId], references: [id], onDelete: SetNull)
  incomingEvent   IncomingEvent?   @relation(fields: [incomingEventId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())

  @@index([tenantId, contactId, createdAt])
  @@index([tenantId, ticketId, createdAt])
  @@index([tenantId, processId, createdAt])
  @@index([tenantId, financialRecordId, createdAt])
  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, channel, externalThreadId])
  @@map("ticket_messages")
}

model AgentConversation {
  id                    String    @id @default(uuid())
  tenantId              String
  ticketId              String?
  contactId             String?
  connectionId          String?
  processId             String?
  assignedUserId        String?
  channel               String
  kind                  String    @default("DIRECT")
  status                String    @default("OPEN")
  priority              String    @default("MEDIUM")
  queue                 String?
  source                String?
  isInternal            Boolean   @default(false)
  title                 String?
  externalThreadId      String?
  externalParticipantId String?
  waitingReply          Boolean   @default(false)
  unreadCount           Int       @default(0)
  lastMessagePreview    String?
  startedAt             DateTime  @default(now())
  closedAt              DateTime?
  lastMessageAt         DateTime? @default(now())
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  ticket       Ticket?            @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  contact      Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  connection   Connection?        @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  process      Process?           @relation(fields: [processId], references: [id], onDelete: SetNull)
  assignee     User?              @relation("AssignedAgentConversations", fields: [assignedUserId], references: [id], onDelete: SetNull)
  participants AgentParticipant[]
  messages     AgentMessage[]
  runs         AgentRun[]

  @@index([tenantId, channel, status, lastMessageAt])
  @@index([ticketId])
  @@index([contactId])
  @@index([connectionId])
  @@index([processId])
  @@index([assignedUserId])
  @@index([tenantId, externalThreadId])
  @@map("agent_conversations")
}

model AgentMessage {
  id                String    @id @default(uuid())
  conversationId    String
  tenantId          String
  ticketMessageId   String?
  participantId     String?
  direction         String
  role              String
  content           String    @db.Text
  contentType       String    @default("TEXT")
  status            String    @default("RECEIVED")
  externalMessageId String?
  senderName        String?
  senderAddress     String?
  senderPhone       String?
  senderFullId      String?
  senderLid         String?
  mediaUrl          String?
  metadata          Json?
  editedAt          DateTime?
  createdAt         DateTime  @default(now())

  conversation AgentConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  participant  AgentParticipant?   @relation(fields: [participantId], references: [id], onDelete: SetNull)
  events       AgentMessageEvent[]
  links        AgentMessageLink[]

  @@index([conversationId, createdAt])
  @@index([ticketMessageId])
  @@index([tenantId, externalMessageId])
  @@map("agent_messages")
}

model AgentParticipant {
  id              String    @id @default(uuid())
  tenantId        String
  conversationId  String
  userId          String?
  contactId       String?
  role            String    @default("MEMBER")
  label           String?
  externalAddress String?
  isPrimary       Boolean   @default(false)
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?
  metadata        Json?

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?             @relation("AgentParticipantUser", fields: [userId], references: [id], onDelete: SetNull)
  contact      Contact?          @relation("AgentParticipantContact", fields: [contactId], references: [id], onDelete: SetNull)
  messages     AgentMessage[]

  @@index([conversationId, role])
  @@index([tenantId, userId])
  @@index([tenantId, contactId])
  @@map("agent_participants")
}

model AgentMessageEvent {
  id        String   @id @default(uuid())
  tenantId  String
  messageId String
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  message AgentMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([tenantId, type, createdAt])
  @@map("agent_message_events")
}

model AgentMessageLink {
  id             String   @id @default(uuid())
  tenantId       String
  messageId      String
  processId      String?
  timelineId     String?
  linkedByUserId String?
  kind           String   @default("PROCESS_TIMELINE")
  metadata       Json?
  createdAt      DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  message  AgentMessage     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  process  Process?         @relation(fields: [processId], references: [id], onDelete: SetNull)
  timeline ProcessTimeline? @relation(fields: [timelineId], references: [id], onDelete: SetNull)
  linkedBy User?            @relation("AgentMessageLinkedBy", fields: [linkedByUserId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([tenantId, processId])
  @@index([timelineId])
  @@map("agent_message_links")
}

model AgentRun {
  id             String    @id @default(uuid())
  conversationId String
  tenantId       String
  trigger        String
  channel        String
  status         String    @default("PENDING")
  summary        String?
  metadata       Json?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id])

  @@index([conversationId, startedAt])
  @@index([tenantId, channel, status])
  @@map("agent_runs")
}

model WaInstance {
  id        String  @id @default(uuid())
  tenantId  String
  name      String
  status    String // DISCONNECTED, PAIRING, CONNECTED
  qrCode    String? @db.Text
  serverUrl String?
  apiKey    String?

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  updatedAt DateTime @updatedAt

  @@map("wa_instances")
}

model Connection {
  id       String @id @default(uuid())
  tenantId String
  name     String
  type     String // WHATSAPP, INSTAGRAM, EMAIL
  status   String // CONNECTED, DISCONNECTED, PAIRING, ERROR

  config Json? // Credentials, tokens, settings
  qrCode String? @db.Text

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  agentConversations AgentConversation[]
  ticketMessages     TicketMessage[]
  incomingEvents     IncomingEvent[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("connections")
}

// 9. CICLO DE VENDA: ORÇAMENTOS E FISCAL
model Proposal {
  id          String  @id @default(uuid())
  tenantId    String
  contactId   String
  code        Int     @default(autoincrement())
  status      String // DRAFT, SENT, APPROVED, REJECTED, INVOICED
  totalAmount Decimal @db.Decimal(15, 2)
  notes       String? @db.Text

  // Custom fields for Legacy Layout match
  validUntil         DateTime?
  deliveryDate       DateTime?
  salesperson        String?
  special            Boolean   @default(false)
  paymentCondition   String? // Legado (texto)
  paymentConditionId String? // FK para a Condição de Pagamento (nova estrutura)

  paymentConditionRel PaymentCondition? @relation(fields: [paymentConditionId], references: [id])

  items            ProposalItem[]
  invoices         Invoice[]
  financialRecords FinancialRecord[]
  contact          Contact           @relation("ProposalClient", fields: [contactId], references: [id])
  sellerId         String? // Quem está vendendo (Vendedor/Emissor)
  seller           Contact?          @relation("ProposalSeller", fields: [sellerId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("proposals")
}

model ProposalItem {
  id         String   @id @default(uuid())
  proposalId String
  productId  String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  discount   Decimal? @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@map("proposal_items")
}

model Invoice {
  id                    String           @id @default(uuid())
  tenantId              String
  proposalId            String?
  purchaseOrderId       String?          @unique
  contactId             String
  documentModel         String           @default("NFE") // NFE, NFSE
  direction             String           @default("OUTPUT") // INPUT, OUTPUT
  scope                 String           @default("FULL") // FULL, PRODUCTS, SERVICES
  environment           String?          @default("HOMOLOGATION")
  provider              String?
  providerCityCode      String?
  series                Int?
  number                String?
  accessKey             String?          @unique
  receiptNumber         String?
  batchNumber           String?
  operationNature       String?
  issueDate             DateTime?
  authorizationProtocol String?
  authorizationDate     DateTime?
  rejectionCode         String?
  rejectionMessage      String?          @db.Text
  cancelReason          String?          @db.Text
  cancelProtocol        String?
  xmlContent            String?          @db.Text
  xmlDraft              String?          @db.Text
  xmlAuthorized         String?          @db.Text
  xmlCancelled          String?          @db.Text
  pdfUrl                String?
  requestPayload        Json?
  responsePayload       Json?
  readinessIssues       Json?
  type                  String // INPUT (Compra) ou OUTPUT (Venda)
  status                String // DRAFT, READY, VALIDATING, TRANSMITTING, AUTHORIZED, REJECTED, CANCELLED, PARTIALLY_AUTHORIZED
  financialId           String?          @unique
  proposal              Proposal?        @relation(fields: [proposalId], references: [id])
  purchaseOrder         PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  contact               Contact          @relation(fields: [contactId], references: [id])
  financial             FinancialRecord? @relation(fields: [financialId], references: [id])
  tenant                Tenant           @relation(fields: [tenantId], references: [id])
  items                 InvoiceItem[]
  events                InvoiceEvent[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @default(now()) @updatedAt

  @@index([tenantId, proposalId])
  @@index([tenantId, documentModel, status])
  @@map("invoices")
}

model FiscalConfig {
  id                         String    @id @default(uuid())
  tenantId                   String    @unique
  razaoSocialEmitente        String?
  nomeFantasiaEmitente       String?
  cnpjEmitente               String?
  ieEmitente                 String?
  imEmitente                 String?
  crt                        String?
  regimeTributario           String?
  serieNfe                   Int       @default(1)
  serieNfse                  Int       @default(1)
  proximoNumeroNfe           Int       @default(1)
  proximoNumeroNfse          Int       @default(1)
  proximoNumeroRps           Int       @default(1)
  codigoMunicipioIbge        String?
  codigoMunicipioNfse        String?
  provedorNfse               String?
  webserviceUf               String?
  environment                String    @default("HOMOLOGATION")
  certificatePfx             String?   @db.Text
  certificatePass            String?
  certificateStorageProvider String?
  certificateFileUrl         String?
  certificateLastSyncAt      DateTime?
  certificateExpiresAt       DateTime?
  certificateSerialNumber    String?
  securitySecretId           String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @default(now()) @updatedAt
  tenant                     Tenant    @relation(fields: [tenantId], references: [id])

  @@map("fiscal_configs")
}

model InvoiceItem {
  id                   String   @id @default(uuid())
  invoiceId            String
  productId            String?
  description          String
  quantity             Int
  unit                 String?
  unitPrice            Decimal  @db.Decimal(10, 2)
  grossAmount          Decimal  @db.Decimal(15, 2)
  discountAmount       Decimal? @db.Decimal(15, 2)
  netAmount            Decimal  @db.Decimal(15, 2)
  cfop                 String?
  ncm                  String?
  cest                 String?
  serviceCode          String?
  serviceCodeMunicipal String?
  nbs                  String?
  origin               String?
  cst                  String?
  csosn                String?
  icmsBase             Decimal? @db.Decimal(15, 2)
  icmsRate             Decimal? @db.Decimal(8, 4)
  icmsAmount           Decimal? @db.Decimal(15, 2)
  ipiRate              Decimal? @db.Decimal(8, 4)
  ipiAmount            Decimal? @db.Decimal(15, 2)
  pisCst               String?
  pisRate              Decimal? @db.Decimal(8, 4)
  pisAmount            Decimal? @db.Decimal(15, 2)
  cofinsCst            String?
  cofinsRate           Decimal? @db.Decimal(8, 4)
  cofinsAmount         Decimal? @db.Decimal(15, 2)
  issRate              Decimal? @db.Decimal(8, 4)
  issAmount            Decimal? @db.Decimal(15, 2)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation("ProductInvoiceItems", fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoiceEvent {
  id              String   @id @default(uuid())
  invoiceId       String
  type            String
  status          String
  payload         Json?
  externalCode    String?
  externalMessage String?  @db.Text
  createdAt       DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@map("invoice_events")
}

model PurchaseOrder {
  id          String  @id @default(uuid())
  tenantId    String
  contactId   String // Fornecedor
  buyerId     String? // Comprador
  code        Int     @default(autoincrement())
  status      String // DRAFT, QUOTATION, APPROVED, RECEIVED, CANCELLED
  totalAmount Decimal @db.Decimal(15, 2)
  notes       String? @db.Text

  expectedDate       DateTime?
  deliveryDate       DateTime?
  paymentCondition   String? // Legado (texto)
  paymentConditionId String? // FK para a Condição de Pagamento (nova estrutura)

  paymentConditionRel PaymentCondition? @relation(fields: [paymentConditionId], references: [id])

  items            PurchaseOrderItem[]
  invoice          Invoice?
  financialRecords FinancialRecord[]

  contact   Contact  @relation(fields: [contactId], references: [id])
  buyer     Contact? @relation("PurchaseOrderBuyer", fields: [buyerId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal  @db.Decimal(10, 2)
  discount        Decimal? @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// 10. FORMAS / CONDIÇÕES DE PAGAMENTO
model PaymentCondition {
  id        String  @id @default(uuid())
  tenantId  String
  code      Int     @default(autoincrement()) // Para listar no UI
  name      String // Ex: 5 parcelas
  surcharge Decimal @default(0) @db.Decimal(5, 2) // Acréscimo (%)
  discount  Decimal @default(0) @db.Decimal(5, 2) // Desconto (%)
  active    Boolean @default(true)

  installments     PaymentConditionInstallment[]
  proposals        Proposal[]
  purchaseOrders   PurchaseOrder[]
  financialRecords FinancialRecord[]
  inventoryConfigs InventoryConfig[]

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("payment_conditions")
}

model PaymentConditionInstallment {
  id                 String  @id @default(uuid())
  paymentConditionId String
  installment        Int // 1, 2, 3...
  days               Int // Prazo em dias: 0 (a vista), 30, 60...
  percentage         Decimal @db.Decimal(5, 2) // Percentual do total (%)

  paymentCondition PaymentCondition @relation(fields: [paymentConditionId], references: [id], onDelete: Cascade)

  @@map("payment_condition_installments")
}

model InventoryConfig {
  id           String  @id @default(uuid())
  tenantId     String  @unique
  profitMargin Decimal @default(30) @db.Decimal(5, 2)

  // Configurações Padrão de Orçamento
  defaultSellerId           String?
  defaultPaymentConditionId String?
  defaultNotes              String? @db.Text
  defaultValidityDays       Int     @default(7)

  defaultSeller           Contact?          @relation("InventoryConfigDefaultSeller", fields: [defaultSellerId], references: [id])
  defaultPaymentCondition PaymentCondition? @relation(fields: [defaultPaymentConditionId], references: [id])

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inventory_configs")
}

model SecuritySecret {
  id          String    @id @default(uuid())
  tenantId    String
  entityType  String // BANK_ACCOUNT, CONTACT, PROCESS, etc.
  expiresAt   DateTime?
  fileUrl     String? // Caminho do arquivo criptografado
  entityId    String
  description String
  username    String?
  password    String? // Encrypted / Hash
  link        String?
  privateKey  String?   @db.Text
  publicKey   String?   @db.Text
  details     String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([entityId, entityType])
  @@map("security_secrets")
}

model SecuritySetting {
  id          String  @id @default(uuid())
  tenantId    String
  entityType  String
  entityId    String
  observation String? @db.Text

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType, entityId])
  @@map("security_settings")
}

// 11. WORKFLOWS / ESTEIRAS DE TRABALHO
model Workflow {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  steps     WorkflowStep[]
  processes Process[]

  @@unique([tenantId, name])
  @@map("workflows")
}

model WorkflowStep {
  id         String @id @default(uuid())
  workflowId String
  order      Int

  taskTitle    String
  description  String? @db.Text
  taskCategory String  @default("ACAO") // REGISTRO, ACAO, AGENDA
  taskPriority String  @default("MEDIA") // BAIXA, MEDIA, ALTA, URGENTE

  daysToInternal      Int?
  daysToFatal         Int?
  defaultAssigneeRole String? // Tipo de parte (Role) ou ID do Usuário

  // Next step trigger - store as JSON array of taskTitles or IDs if needed, keeping simple string[] for PostgreSQL
  nextStepIds String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow  Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  timelines ProcessTimeline[]

  @@unique([workflowId, order, taskTitle])
  @@map("workflow_steps")
}
