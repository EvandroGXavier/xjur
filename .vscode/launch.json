{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "🌐 Dr.X Web (Frontend Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/apps/web",
            "sourceMaps": true,
            "presentation": {
                "hidden": false,
                "group": "Dr. X"
            }
        },
        {
            "name": "⚙️ Dr.X API (Backend NestJS)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/api",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "start:debug"],
            "console": "integratedTerminal",
            "restart": true,
            "sourceMaps": true,
            "presentation": {
                "hidden": false,
                "group": "Dr. X"
            }
        }
    ],
    "compounds": [
        {
            "name": "🚀 Executar Dr.X Completo (API + Web)",
            "configurations": ["⚙️ Dr.X API (Backend NestJS)", "🌐 Dr.X Web (Frontend Chrome)"],
            "stopAll": true
        }
    ]
}